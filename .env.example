GUARDRAILS_ENCODER=answerdotai/ModernBERT-base
# PIGuard (aka InjecGuard) training set. Accepts HF Hub IDs or JSON/JSONL URLs.
GUARDRAILS_DATASET=https://raw.githubusercontent.com/leolee99/PIGuard/main/datasets/train.json
GUARDRAILS_TEXT_COLUMN=prompt
GUARDRAILS_LABEL_COLUMN=label
GUARDRAILS_MAX_SEQ_LEN=1024
GUARDRAILS_BATCH_SIZE=16
GUARDRAILS_EVAL_BATCH_SIZE=32
GUARDRAILS_GRAD_ACCUM_STEPS=4
GUARDRAILS_LEARNING_RATE=2e-5
GUARDRAILS_WEIGHT_DECAY=0.01
GUARDRAILS_WARMUP_RATIO=0.1
GUARDRAILS_NUM_EPOCHS=2
GUARDRAILS_GROUP_BY_LENGTH=true
GUARDRAILS_AUGMENT_HARD_NEGATIVES=true
# WildJailbreak adversarial-benign augmentation. Gated on HF — accept the AI2
# Responsible Use licence at https://huggingface.co/datasets/allenai/wildjailbreak
# and run `hf auth login` before enabling.
GUARDRAILS_AUGMENT_WILDJAILBREAK=false
GUARDRAILS_AUGMENT_WILDJAILBREAK_N=30000
GUARDRAILS_PRECISION=bf16
GUARDRAILS_OUTPUT_DIR=checkpoints
GUARDRAILS_DEVICE=mps
GUARDRAILS_SEED=42
# HTTP server defaults. Listen on 0.0.0.0 to expose to the network; put behind
# a reverse proxy for auth/TLS. `guardrails serve` reads these unless --host/--port override.
GUARDRAILS_SERVER_HOST=127.0.0.1
GUARDRAILS_SERVER_PORT=8080
GUARDRAILS_SERVER_MAX_PROMPT_CHARS=100000
